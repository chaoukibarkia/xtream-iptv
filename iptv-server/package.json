{
  "name": "iptv-server",
  "version": "1.0.0",
  "description": "Xtream Codes compatible IPTV streaming server",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-rbac": "tsx prisma/seed-rbac.ts",
    "db:seed-all": "tsx prisma/seed.ts && tsx prisma/seed-rbac.ts",
    "lint": "eslint src --ext .ts",
    "test": "vitest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "iptv",
    "streaming",
    "xtream-codes",
    "hls",
    "ffmpeg"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.16",
    "axios": "^1.7.7",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fluent-ffmpeg": "^2.1.3",
    "geoip-lite": "^1.4.10",
    "ioredis": "^5.4.1",
    "maxmind": "^5.0.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "uuid": "^10.0.0",
    "xml2js": "^0.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^6.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/geoip-lite": "^1.4.4",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
