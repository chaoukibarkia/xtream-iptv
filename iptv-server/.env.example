# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/iptv_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Secret (generate a strong random string)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Server Info (for Xtream Codes API responses)
SERVER_URL="http://localhost"
SERVER_PORT="3000"
SERVER_HTTPS_PORT="443"
RTMP_PORT="1935"
TIMEZONE="UTC"

# FFmpeg
FFMPEG_PATH="/usr/bin/ffmpeg"
HLS_SEGMENT_PATH="/tmp/hls-segments"

# Multi-Server (optional)
SERVER_ID=1
SERVER_NAME="main-server"
SERVER_API_KEY=""
MAIN_PANEL_URL=""

# Load Balancer
USE_REDIRECT="false"

# Logging
LOG_LEVEL="info"

# Admin API (generate a strong random string, min 16 chars)
ADMIN_API_KEY="change-this-to-a-secure-random-key"
