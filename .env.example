# ============================================
# IPTV System - Environment Configuration
# ============================================
# Copy this file to .env and update values
# ============================================

# ==========================================
# TMDB Integration
# ==========================================
TMDB_API_KEY=your-tmdb-api-key-here

# ==========================================
# Security
# ==========================================
ADMIN_API_KEY=change-this-to-a-secure-key

# ==========================================
# Database (only change if using external DB)
# ==========================================
# POSTGRES_USER=iptv
# POSTGRES_PASSWORD=iptv_secret
# POSTGRES_DB=iptv_db

# ==========================================
# Server URLs (update for production)
# ==========================================
# SERVER_URL=https://your-domain.com
# SERVER_PORT=3001
# SERVER_HTTPS_PORT=443
