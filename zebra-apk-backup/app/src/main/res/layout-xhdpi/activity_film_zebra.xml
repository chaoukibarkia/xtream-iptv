<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/iptvconstraint"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/vod_bg"
    android:orientation="horizontal" android:layoutDirection="ltr"
    tools:context="zb.zebra.FilmZebraActivity">


    <android.support.v7.widget.RecyclerView
        android:id="@+id/recyclerView" android:layoutDirection="ltr"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:descendantFocusability="afterDescendants"
        android:focusable="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:layout_constraintBottom_toBottomOf="@id/recyclerViewbottom"
        app:layout_constraintEnd_toEndOf="@id/recyclerViewright"
        app:layout_constraintStart_toStartOf="@+id/epgRight"
        app:layout_constraintTop_toTopOf="@id/recyclerViewtop"
        tools:context="zb.zebra.zebra.FilmZebraActivity"
        tools:showIn="@layout/activity_film_zebra" />

    <android.support.constraint.ConstraintLayout
        android:id="@+id/channellistRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/channellistbg"
            app:layout_constraintBottom_toTopOf="@id/channellistBottom2"
            app:layout_constraintLeft_toLeftOf="@id/channellistLeft2"
            app:layout_constraintRight_toRightOf="@id/channellistRight2"
            app:layout_constraintTop_toTopOf="@id/tvgenretop" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/vod_fg" />

        <android.support.constraint.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toTopOf="@id/channellistTop"
            app:layout_constraintLeft_toLeftOf="@id/channellistLeft"
            app:layout_constraintRight_toRightOf="@id/channellistRight2"
            app:layout_constraintTop_toTopOf="@id/tvgenretop">

            <TextView
                android:id="@+id/filmsLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                android:text="FILMS"
                android:textAlignment="center"
                android:textColor="@android:color/white"
                android:textSize="@dimen/filmssize"

                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </android.support.constraint.ConstraintLayout>

        <android.support.constraint.Guideline
            android:id="@+id/tvgenretop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.02" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.02" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistLeft2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.02" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.14" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.23" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistRight2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.23" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.68" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistBottom2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.98" />


        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"

            app:layout_constraintBottom_toTopOf="@id/channellistBottom"
            app:layout_constraintLeft_toRightOf="@id/channellistLeft"
            app:layout_constraintRight_toLeftOf="@id/channellistRight"
            app:layout_constraintTop_toBottomOf="@id/channellistTop">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:orientation="vertical">


                <LinearLayout
                    android:id="@+id/vodcategories"
                    android:layout_width="match_parent"


                    android:layout_height="match_parent"


                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">


                        <EditText
                            android:id="@+id/searchinput"
                            style="@style/Widget.AppCompat.EditText"
                            android:layout_width="match_parent"
                            android:layout_height="100px"
                            android:background="@drawable/edit_text"
                            android:ems="10"
                            android:drawableRight="@drawable/search"
                            android:layout_marginBottom="3px"
                            android:paddingLeft="10px"
                            android:hint="Recherche"
                            android:inputType="text"
                            android:imeOptions="actionSearch"
                            android:singleLine="true" />

                        <ListView
                            android:id="@+id/categoriesList"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:listSelector="@drawable/channelitembgselected" ><requestFocus/></ListView>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>




    </android.support.constraint.ConstraintLayout>


    <android.support.constraint.Guideline
        android:id="@+id/guidelineepg2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.65" />


    <android.support.constraint.Guideline
        android:id="@+id/guideline2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.7" />

    <android.support.constraint.Guideline
        android:id="@+id/guidelineepgviewtop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.77" />


    <android.support.constraint.Guideline
        android:id="@+id/epgRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.225" />
    <android.support.constraint.Guideline
        android:id="@+id/recyclerViewbottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.98" />
    <android.support.constraint.Guideline
        android:id="@+id/recyclerViewright"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.98" />
    <android.support.constraint.Guideline
        android:id="@+id/recyclerViewtop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.02" />

    <TextView
        android:id="@+id/filmtitle"
        android:layout_width="184dp"
        android:layout_height="wrap_content"
        android:ellipsize="marquee"
        android:singleLine="true"
        android:textAlignment="center"
        android:textColor="@color/lb_tv_white"
        app:layout_constraintEnd_toStartOf="@+id/epgRight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guideline2"
        android:text="" />

    <ImageView android:id="@+id/star"
        android:layout_width="50dp"
        android:layout_height="0dp"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toTopOf="@id/imageView3"
        app:layout_constraintEnd_toStartOf="@+id/epgRight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/filmtitle"
        android:src="@drawable/star"
        />
    <TextView
        android:id="@+id/filmRating"
        android:layout_width="144dp"
        android:layout_height="wrap_content"
        android:textColor="@color/lb_tv_white"
        android:textAlignment="center"
        app:layout_constraintEnd_toStartOf="@+id/epgRight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/star"
        android:text="" />
    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="144dp"
        android:layout_height="0dp"
        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/epgRight"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/guidelineepgviewtop"
        app:srcCompat="@drawable/logo" />


</android.support.constraint.ConstraintLayout>
