<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="500dp"

    android:layout_height="210dp" android:background="@drawable/popbgn"  android:orientation="vertical" >
    <ImageView
        android:src="@null"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:scaleType="fitCenter"
        android:padding="5dp"

        android:contentDescription="@string/app_name" />
    <TextView
        android:id="@+id/currentversiontxtv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAlignment="center"
        android:layout_marginTop="10dp"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp" android:textColor="@android:color/white"
        android:layout_marginBottom="4dp"/>
    <TextView
        android:id="@+id/changelogmsgtxtv"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp" android:textColor="@android:color/white"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center" android:layout_marginTop="10dp"
        android:background="@android:color/transparent"
        android:orientation="horizontal" >

        <Button
            android:id="@+id/btn_yes"
            android:layout_width="wrap_content"
            android:layout_height="30dp" android:layout_margin="10dp"
            android:background="@drawable/selector_btn"
            android:textColor="@color/audio_color" android:padding="5dp"
            android:clickable="true"
            android:text="Mettre à jour"
            android:textStyle="bold" />



            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>