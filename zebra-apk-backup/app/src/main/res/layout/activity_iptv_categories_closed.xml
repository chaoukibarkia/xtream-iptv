<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/iptvconstraint"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBlack"
    android:orientation="horizontal" android:layoutDirection="ltr"
    tools:context="zb.zebra.IptvActivity">



    <com.google.android.exoplayer2.ui.SimpleExoPlayerView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:focusable="false"
        app:use_controller="false" />
    <LinearLayout android:id="@+id/badsignal" android:orientation="horizontal"
        android:layout_width="wrap_content" android:visibility="invisible"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/error2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    </LinearLayout>

    <LinearLayout android:id="@+id/disconnected" android:orientation="horizontal"
        android:layout_width="wrap_content" android:visibility="invisible"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginLeft="8dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/errortoast"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

    </LinearLayout>


    <android.support.constraint.ConstraintLayout
        android:id="@+id/channellistRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/channellistbg"
            app:layout_constraintBottom_toTopOf="@id/channellistBottom2"
            app:layout_constraintLeft_toLeftOf="@id/channellistLeft2"
            app:layout_constraintRight_toRightOf="@id/channellistRight2"
            app:layout_constraintTop_toTopOf="@id/tvgenretop" />

<android.support.constraint.ConstraintLayout
    android:layout_width="0dp"
    android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@id/channellistTop"
    app:layout_constraintLeft_toLeftOf="@id/channellistLeft"
    app:layout_constraintRight_toRightOf="@id/channellistRight2"
    app:layout_constraintTop_toTopOf="@id/tvgenretop">

    <TextSwitcher
        android:id="@+id/spinner2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAlignment="center"


        android:layout_marginBottom="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</android.support.constraint.ConstraintLayout>

        <android.support.constraint.Guideline
            android:id="@+id/tvgenretop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistLeft2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.12" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.35" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistRight2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.368" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.7" />

        <android.support.constraint.Guideline
            android:id="@+id/channellistBottom2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="1" />

        <Spinner
            android:id="@+id/spinner"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:spinnerMode="dropdown"
            android:visibility="invisible"
            app:layout_constraintBottom_toTopOf="@id/channellistTop"
            app:layout_constraintLeft_toLeftOf="@id/channellistLeft"
            app:layout_constraintRight_toRightOf="@id/channellistRight"
            app:layout_constraintTop_toTopOf="@id/tvgenretop" />



        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="horizontal"

            app:layout_constraintBottom_toTopOf="@id/channellistBottom"
            app:layout_constraintLeft_toRightOf="@id/channellistLeft"
            app:layout_constraintRight_toLeftOf="@id/channellistRight"
            app:layout_constraintTop_toBottomOf="@id/channellistTop">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"

                android:orientation="vertical">


                <LinearLayout
                    android:id="@+id/iptvmenu"
                    android:layout_width="match_parent"


                    android:layout_height="match_parent"


                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">


                        <ListView
                            android:id="@+id/channelsList"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:listSelector="@drawable/channelitembgselected"  />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <ImageView
            android:id="@+id/chevronup"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_keyboard_arrow_up_black_24dp"
            app:layout_constraintLeft_toRightOf="@id/channellistLeft"
            app:layout_constraintRight_toLeftOf="@id/channellistRight"
            app:layout_constraintBottom_toTopOf="@+id/channellistTop"/>
        <ImageView
            android:id="@+id/listviewmask"
            android:layout_width="0dp"
            android:layout_height="@dimen/listviewmaskheight"
            android:src="@drawable/gradientend"
            app:layout_constraintLeft_toRightOf="@id/channellistLeft"
            app:layout_constraintRight_toLeftOf="@id/channellistRight"
            app:layout_constraintBottom_toBottomOf="@+id/channellistBottom"/>
        <ImageView
            android:id="@+id/chevrondown"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_keyboard_arrow_down_black_24dp"
            app:layout_constraintLeft_toRightOf="@id/channellistLeft"
            app:layout_constraintRight_toLeftOf="@id/channellistRight"
            app:layout_constraintTop_toBottomOf="@+id/listviewmask"/>
    </android.support.constraint.ConstraintLayout>


    <android.support.constraint.ConstraintLayout
        android:id="@+id/programmelistRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="invisible">
        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/channellistbg"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="@id/guidelineepg"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <android.support.constraint.Guideline
            android:id="@+id/programmelistTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.1" />
        <android.support.constraint.Guideline
            android:id="@+id/guidelineepg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.77" />
        <android.support.constraint.Guideline
            android:id="@+id/programmetop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.03" />
        <android.support.constraint.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="0dp" app:layout_constraintBottom_toTopOf="@id/programmelistTop"
            app:layout_constraintLeft_toLeftOf="@id/guidelineepg"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@id/programmetop">

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:text="PROGRAMMES"
                android:textColor="@android:color/white"
                android:textSize="@dimen/iptvitemssize"
                android:textStyle="bold" android:layout_marginBottom="8dp"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
        </android.support.constraint.ConstraintLayout>
        <android.support.constraint.Guideline
            android:id="@+id/epglistTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.12" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"


            android:orientation="horizontal"
            app:layout_constraintBottom_toTopOf="@id/programmelistviewmaskguide"
            app:layout_constraintLeft_toRightOf="@id/guidelineepg"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@id/epglistTop">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <ListView
                    android:id="@+id/programmesList" android:clickable="true" android:scrollingCache="false"
                    android:smoothScrollbar="true"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:listSelector="@drawable/channelitembgselected" />
            </LinearLayout>


        </LinearLayout>
        <ImageView
            android:id="@+id/programmelistviewmask"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:src="@drawable/gradientend"
            app:layout_constraintLeft_toRightOf="@id/guidelineepg"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
        <ImageView
            android:id="@+id/programmelistchevrondown"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_keyboard_arrow_down_black_24dp"
            app:layout_constraintLeft_toRightOf="@id/guidelineepg"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@id/programmelistviewmask" />

        <android.support.constraint.Guideline
            android:id="@+id/programmelistviewmaskguide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.88" />
    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.Guideline
        android:id="@+id/guidelineepg2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.77" />
    <android.support.constraint.ConstraintLayout
        android:id="@+id/archiveview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="invisible"
        android:background="@drawable/channellistbg"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@id/guidelineepg2"
        app:layout_constraintTop_toTopOf="@id/guidelineepgviewtop">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">
            <TextView
                android:id="@+id/selectedProgram"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:layout_marginLeft="10dp"
                android:textColor="@android:color/white"
                android:textSize="20sp" android:textStyle="bold" />
            <TextView
                android:id="@+id/selectedProgramDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:text=""
                android:textColor="@android:color/white"
                android:textSize="18sp" />
        </LinearLayout>



    </android.support.constraint.ConstraintLayout>

    <android.support.constraint.Guideline
        android:id="@+id/guideline2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.7" />
    <android.support.constraint.Guideline
        android:id="@+id/guidelineepgviewtop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.77" />




















    <android.support.constraint.Guideline
        android:id="@+id/epgRight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.35" />

    <android.support.constraint.ConstraintLayout
        android:id="@+id/epgview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"

        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="@id/epgRight"
        app:layout_constraintTop_toTopOf="@id/guideline2">

        <LinearLayout
            android:id="@+id/channelinfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">




        </LinearLayout>

        <TextView
            android:id="@+id/currentProgram"  android:ellipsize="marquee"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:paddingTop="@dimen/paddingtopgenre"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"
            android:text=""
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size"
            android:paddingBottom="@dimen/programmbottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <android.support.constraint.Guideline
            android:id="@+id/epgLeft"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.1" />
        <TextView
            android:id="@+id/nextProgtime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"
            android:text=""
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/currentProgram" />
        <TextView
            android:id="@+id/nextProgram"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginEnd="8dp"
            android:layout_marginStart="8dp"
            android:text=""
            android:marqueeRepeatLimit="marquee_forever"
            android:scrollHorizontally="true"
            android:singleLine="true"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size"
            app:layout_constraintEnd_toEndOf="parent"
            android:focusable="true"
            android:focusableInTouchMode="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/nextProgtime" />

    </android.support.constraint.ConstraintLayout>
    <LinearLayout
        android:id="@+id/audiosubmenu"
        android:layout_width="160dp"
        android:layout_height="wrap_content"
        android:background="@drawable/selector_btn"
        android:orientation="vertical"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/iptvaudiobtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/selector_btn"
            android:nextFocusUp="@id/iptvsubbtn"
            android:nextFocusDown="@id/iptvsubbtn"
            android:padding="5dp"
            android:text="AUDIOS"
            android:textColor="@color/audio_color" />

        <Button
            android:id="@+id/iptvsubbtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/selector_btn"
            android:nextFocusUp="@id/iptvaudiobtn"
            android:nextFocusDown="@id/iptvaudiobtn"
            android:padding="5dp"
            android:text="SUBTITLES"
            android:textColor="@color/audio_color" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/audiomenu"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:visibility="invisible"
        android:background="@drawable/selector_btn"
        android:orientation="vertical" app:layout_constraintLeft_toLeftOf="parent" app:layout_constraintRight_toRightOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
    </LinearLayout>
    <LinearLayout
        android:id="@+id/subtitlemenu"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:visibility="invisible"
        android:background="@drawable/selector_btn"
        android:orientation="vertical" app:layout_constraintLeft_toLeftOf="parent" app:layout_constraintRight_toRightOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
    </LinearLayout>
    <android.support.constraint.ConstraintLayout
        android:id="@+id/countryside" android:visibility="invisible"
        android:layout_width="0dp"
        android:layout_height="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" android:background="@color/colorBlackTransparent2"  app:layout_constraintRight_toLeftOf="@id/countrylistRight2" app:layout_constraintLeft_toRightOf="@id/countrylistLeft2">
        <android.support.constraint.ConstraintLayout
        android:layout_width="0dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
            android:layout_height="0dp" android:background="@drawable/colorblackwithborder" app:layout_constraintLeft_toLeftOf="parent" app:layout_constraintRight_toLeftOf="@id/countrylistRight">
            <TextView
                android:layout_width="match_parent" android:id="@+id/categoriesLabel"
                android:layout_height="wrap_content" android:textSize="25dp" android:textAlignment="center"

                android:textColor="@android:color/white"

                android:textStyle="bold" android:layout_marginBottom="60dp" android:height="60dp"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp" android:text="PAYS"/>
        <ListView
            android:id="@+id/countryList" android:clickable="true" android:scrollingCache="false"
            android:smoothScrollbar="true"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:textColor="@color/listviewtext_color"
            app:layout_constraintTop_toBottomOf="@id/categoriesLabel"
            app:layout_constraintBottom_toBottomOf="parent"
            android:listSelector="@drawable/channelitembgselected" />

    </android.support.constraint.ConstraintLayout>
        <android.support.constraint.Guideline
            android:id="@+id/countrylistRight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.75" />
    </android.support.constraint.ConstraintLayout>
    <android.support.constraint.Guideline
        android:id="@+id/countrylistRight2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0" />
    <android.support.constraint.Guideline
        android:id="@+id/countrylistLeft2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="-0.35" />

</android.support.constraint.ConstraintLayout>
