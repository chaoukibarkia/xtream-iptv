# ============================================
# IPTV System - Environment Variables
# ============================================
# Copy to /etc/containers/systemd/iptv.env and customize
# Then reference in Quadlet files with:
# EnvironmentFile=/etc/containers/systemd/iptv.env
# ============================================

# Server Configuration
NODE_ENV=production
SERVER_URL=http://your-domain.com
SERVER_PORT=3001
SERVER_HTTPS_PORT=443
SERVER_RTMP_PORT=1935
SERVER_TIMEZONE=UTC

# Database Configuration
POSTGRES_USER=iptv
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=iptv_db
DATABASE_URL=postgresql://iptv:change-this-secure-password@localhost:5432/iptv_db?connection_limit=20&pool_timeout=30&connect_timeout=30

# Redis Configuration
REDIS_URL=redis://localhost:6379

# FFmpeg Configuration
FFMPEG_PATH=/usr/bin/ffmpeg

# Logging
LOG_LEVEL=info

# TMDB Integration (Optional)
TMDB_API_KEY=your-tmdb-api-key-here
TMDB_LANGUAGE=en-US
TMDB_INCLUDE_ADULT=false
TMDB_RATE_LIMIT_MS=250

# Security
ADMIN_API_KEY=change-this-admin-api-key
JWT_SECRET=change-this-jwt-secret-must-be-at-least-32-characters-long

# Frontend Configuration (Build-time)
NEXT_PUBLIC_API_URL=http://your-domain.com:3001
NEXT_PUBLIC_TMDB_IMAGE_BASE=https://image.tmdb.org/t/p
NEXT_PUBLIC_ADMIN_API_KEY=change-this-admin-api-key
